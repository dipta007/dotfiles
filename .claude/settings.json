  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); dir=$(echo \"$input\" | jq -r '.workspace.current_dir'); style=$(echo \"$input\" | jq -r '.output_style.name // \"default\"'); remaining=$(echo \"$input\" | jq -r '.context_window.remaining_percentage // empty'); context_info=''; if [ -n \"$remaining\" ]; then context_info=$(printf \" | Context: %.0f%%\" \"$remaining\"); fi; printf \"%s | %s | Style: %s%s\" \"$model\" \"$(basename \"$dir\")\" \"$style\" \"$context_info\""
  },
