# use bat if available, else use cat
if command -v bat >/dev/null 2>&1; then
    alias cat='bat'
fi

# use rg if available, else use grep
if command -v rg >/dev/null 2>&1; then
    alias grep='rg'
fi

# use fd if available, else use find
if command -v fd >/dev/null 2>&1; then
    alias find='fd'
fi

