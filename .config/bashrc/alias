# use bat if available, else use cat
if command -v bat >/dev/null 2>&1; then
    alias cat='bat'
fi

# use rg if available, else use grep
if command -v rg >/dev/null 2>&1; then
    alias grep='rg'
fi

# use fd if available, else use find
if command -v fd >/dev/null 2>&1; then
    alias find='fd'
fi

# Git worktree
alias gwl="git worktree list"
alias gwa="git worktree add"
alias gwr="git worktree remove"

# General aliases
alias ll='ls -lAFh'                         # Preferred 'ls' implementatioss
alias wget='wget -c'                        # Preferred 'wget' implementation (resume download)
alias c='clear'                             # c:            Clear terminal display
alias path='echo -e ${PATH//:/\\n}'         # path:         Echo all executable Paths
alias gl='git pull'
alias gp='git push'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias lli="ls -lh --color=always | sort -k9 -f"
alias fnv='nvim $(fzf --preview "bat --style=numbers --color=always {}" --layout reverse --border)'


