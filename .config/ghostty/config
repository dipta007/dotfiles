# Font configuration
theme = TokyoNight Night
font-family = JetBrains Mono
# font-family = MesloLGS Nerd Font Mono
font-family = Kohinoor Bangla
font-size = 16

# Keep font size stable across new windows/tabs
window-inherit-font-size = false

# More line spacing = easier to read, less eye strain
adjust-cell-height = 15%

# Window configuration
window-decoration = true
# background-opacity = 0.8
# background-blur-radius = 20
# unfocused-split-opacity = 0.8

# macOS specific
macos-titlebar-style = hidden
window-theme = ghostty

# Quality-of-life
# select text -> straight to clipboard
copy-on-select = clipboard
# hide pointer while typing, less distraction
mouse-hide-while-typing = true
# ask before closing a pane/window (avoid accidental loss)
confirm-close-surface = true

# Focus mode
# background-opacity = 1.0
# background-blur-radius = 0
# unfocused-split-opacity = 1.0

# Solid background = less eye strain. No transparency/blur when reading code all day.
background-opacity = 1.0
unfocused-split-opacity = 0.9

# Never let any text/bg color pair fall below a readable contrast floor
minimum-contrast = 1.05

# Colors now come from `theme = TokyoNight Night` above (matches nvim).
# Old Coolnight neon palette removed 2026-07-17 (high contrast + neon = eye fatigue).
# Full original saved in config.backup-2026-07-17 if you want it back.

# Key binding (Shift+Enter sends escape + return)
keybind = shift+enter=text:\x1b\r
